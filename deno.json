{
  "imports": {
    "grammy": "https://deno.land/x/grammy/mod.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "esnext"]
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --watch bot.ts",
    "dev:env": "deno run --allow-net --allow-env --env --watch bot.ts",
    "start": "deno run --allow-net --allow-env --env bot.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
